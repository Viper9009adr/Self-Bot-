# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here
# Set to "webhook" or "polling"
TELEGRAM_MODE=polling
# Required when MODE=webhook
TELEGRAM_WEBHOOK_URL=https://yourbot.example.com/telegram/webhook
TELEGRAM_WEBHOOK_PORT=8080

# ─── LLM Providers ───────────────────────────────────────────────────────────
# Primary provider: "openai" | "anthropic" | "groq" | "github-models" | "openrouter" | "claude-oauth" | "nvidia-nim" | "local"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# ── Paid API-Key Providers ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ── Free / OAuth Token Providers ─────────────────────────────────────────────

# GitHub Models: Free GPT-4o access via GitHub Personal Access Token.
# Create a PAT (classic or fine-grained) with NO scopes at:
#   https://github.com/settings/tokens/new
# Set LLM_PROVIDER=github-models and LLM_MODEL=gpt-4o (or gpt-4o-mini for higher rate limits)
# Rate limits: ~10 RPM for gpt-4o, ~150 RPM for gpt-4o-mini on free tier
GITHUB_TOKEN=ghp_...

# OpenRouter: Access free-tier models via OpenRouter proxy.
# Sign up and get a free API key at: https://openrouter.ai/keys
# Set LLM_PROVIDER=openrouter and LLM_MODEL to a model slug, e.g.:
#   meta-llama/llama-3.1-8b-instruct:free  (free)
#   google/gemma-2-9b-it:free               (free)
#   openai/gpt-4o                           (paid, pass-through pricing)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_REFERER=https://github.com/your-repo

# Local OpenAI-compatible server for chat (Ollama/LM Studio/vLLM proxy/etc)
# Set LLM_PROVIDER=local and LOCAL_BASE_URL to your chat endpoint (recommended to include /v1)
# LOCAL_BASE_URL=http://localhost:11434/v1
# LOCAL_API_KEY=optional_local_api_key
# Media endpoints are explicit and capability-scoped (no fallback to LOCAL_BASE_URL)
# LOCAL_STT_URL=http://localhost:8001/v1
# LOCAL_TTS_URL=http://localhost:8002/v1
# LOCAL_IMAGE_URL=http://localhost:8003/v1

# Claude Pro/Max via Anthropic PKCE OAuth (uses your existing subscription, no paid API key needed)
# On first run, you will be prompted to authenticate via browser. Tokens are cached in:
#   .oauth-tokens.json (added to .gitignore automatically)
# LLM_PROVIDER=claude-oauth
# LLM_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_OAUTH_TOKENS_PATH=.oauth-tokens.json  # optional, this is the default

# NVIDIA NIM: Free-tier models via NVIDIA's OpenAI-compatible API.
# Sign up at https://build.nvidia.com/ and get an API key (starts with nvapi-)
# Set LLM_PROVIDER=nvidia-nim and LLM_MODEL to a model slug, e.g.:
#   meta/llama-3.1-8b-instruct    (free)
#   deepseek-ai/deepseek-v3.2     (free)
#   google/gemma-2-9b-it          (free)
# NVIDIA_NIM_API_KEY=nvapi-...

# NVIDIA NIM Image Generation (optional — uses same API key as LLM)
# Model slug for image generation. Available models:
#   stabilityai/stable-diffusion-3-medium    (free, default)
#   black-forest-labs/flux-1-schnell         (free)
#   black-forest-labs/flux-1-dev             (free)
# MEDIA_NVIDIA_NIM_IMAGE_MODEL=stabilityai/stable-diffusion-3-medium

# ─── Agent ───────────────────────────────────────────────────────────────────
AGENT_MAX_STEPS=10
AGENT_MAX_HISTORY_TOKENS=8000
AGENT_SYSTEM_PROMPT_EXTRA=
# Progress reporter mode:
# false (default): single-line rotating progress, then edit SAME message to final response (no duplicate send)
# true: persist step history (⚙ in-progress, ✓ done, ⚠ interrupted) and send final response as separate message
PROGRESS_REPORTER_PERSIST_HISTORY=false

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_TTL_SECONDS=3600
# Set to "redis" to enable Redis; defaults to in-memory
SESSION_STORE=memory
# Set to "meridian" to persist sessions via Meridian MCP
# Requires MERIDIAN_SESSION_URL to be set
# SESSION_STORE=meridian
# MERIDIAN_SESSION_URL=https://meridian.example.com

# ─── Redis (optional) ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Set to true to store Redis sessions without expiration (no TTL)
# REDIS_DISABLE_TTL=false

# ─── MCP Server ──────────────────────────────────────────────────────────────
MCP_SERVER_PORT=3001
MCP_SERVER_HOST=127.0.0.1

# ─── Remote MCP Servers ───────────────────────────────────────────────────────
# Optional: comma-separated URLs or JSON array of remote MCP server base URLs.
# Tools from each server are automatically discovered and registered at startup.
#
# JSON array format (recommended):
# MCP_REMOTE_SERVERS=["https://mcp1.example.com","https://mcp2.example.com"]
#
# CSV format:
# MCP_REMOTE_SERVERS=https://mcp1.example.com,https://mcp2.example.com
#
# MCP_REMOTE_SERVERS=

# ─── Browser Worker ──────────────────────────────────────────────────────────
BROWSER_WORKER_URL=http://localhost:3002
BROWSER_WORKER_TIMEOUT_MS=30000

# ─── Queue ───────────────────────────────────────────────────────────────────
QUEUE_CONCURRENCY=4
QUEUE_PER_USER_CONCURRENCY=2

# ─── Migration compatibility flags (default: false) ──────────────────────────
# MIGRATION_ADAPTER_BOUNDARY=false
# MIGRATION_MOBILE_RUNTIME=false

# ─── WhatsApp ────────────────────────────────────────────────────────────────
# Set WA_ENABLED=true to activate the WhatsApp adapter
# WA_OWNER_NUMBER is your WhatsApp number in international format (e.g. +1234567890)
# On first run, a QR code will be displayed in the terminal — scan with WhatsApp mobile app
# Note: WhatsApp text is supported; outbound audio/voice delivery is not yet implemented.
WA_ENABLED=false
# WA_OWNER_NUMBER=+1234567890
# WA_SESSION_PATH=.whatsapp-session

# ─── Website / Dashboard ─────────────────────────────────────────────────────
# Set WEB_ENABLED=true to activate the web dashboard adapter
WEB_ENABLED=false
# WEB_OWNER_USERNAME=admin
# WEB_OWNER_PASSWORD=your_secure_password_here
# WEB_PORT=3000
# WEB_HOST=0.0.0.0

# ─── Access Control ───────────────────────────────────────────────────────────
# Required: bot owner user ID with platform prefix.
# Accepted formats: tg:123456789 (Telegram) | wa:15551234567 (WhatsApp) | web:admin (Website)
BOT_OWNER_ID=tg:your_telegram_user_id_here
# Optional: path to allowlist file (default: .allowlist.json)
# ALLOWLIST_PATH=.allowlist.json
# Optional: set to "false" to send a rejection message to unauthorized users
# ACCESS_SILENT_REJECT=true
# Optional: custom rejection message (only used when ACCESS_SILENT_REJECT=false)
# ACCESS_REJECTION_MESSAGE=Sorry, this bot is private.

# ─── GatewayAuth (JWT + Meridian MCP allowlist) ───────────────────────────────
# Required for web dashboard auth and JWT issuance for permitted users. Must be ≥32 characters.
# Generate with: openssl rand -hex 32
# GATEWAY_JWT_SECRET=your_32_plus_char_secret_here

# Allowlist store backend: "file" (default) or "meridian".
#   file     — persists to ALLOWLIST_PATH (.allowlist.json by default)
#   meridian — persists to a Meridian MCP server (requires MERIDIAN_MCP_URL)
# ALLOWLIST_STORE=file

# Meridian MCP server base URL. Required when ALLOWLIST_STORE=meridian.
# Startup fails with an error if ALLOWLIST_STORE=meridian but this is not set.
# MERIDIAN_MCP_URL=https://meridian.example.com/sse

# ─── Media ───────────────────────────────────────────────────────────────────
# Media routing is capability-scoped:
# - image: LOCAL_IMAGE_URL -> OPENAI_API_KEY -> unavailable
# - stt:   LOCAL_STT_URL   -> OPENAI_API_KEY -> unavailable
# - tts:   LOCAL_TTS_URL   -> (OPENAI_API_KEY + MEDIA_TTS_ENABLED=true) -> unavailable
# LOCAL_BASE_URL is chat-only and is never used as implicit media fallback.
# Image generation model. Default: gpt-image-1 (supports editing). Use dall-e-3 for alternatives.
# MEDIA_IMAGE_MODEL=gpt-image-1
# Default image size (1024x1024 | 1792x1024 | 1024x1792 for dall-e-3; 1024x1024 for gpt-image-1)
# MEDIA_IMAGE_SIZE=1024x1024
# Image quality. For gpt-image-1: low|medium|high|auto. For dall-e-3: standard|hd.
# MEDIA_IMAGE_QUALITY=standard
# Whisper speech-to-text model
# MEDIA_STT_MODEL=whisper-1
# TTS model (tts-1 = fast/cheap, tts-1-hd = higher quality)
# MEDIA_TTS_MODEL=tts-1
# TTS voice: alloy | echo | fable | onyx | nova | shimmer
# MEDIA_TTS_VOICE=alloy
# Set to false to disable TTS even when OPENAI_API_KEY is present
# MEDIA_TTS_ENABLED=true

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development

# ─── Terminal Skills ──────────────────────────────────────────────────────
# Comma-separated list of allowed working directories for terminal sessions.
# Paths are validated with prefix matching (case-sensitive).
# Example: /home,/tmp,/home/username/projects
TERMINAL_CWD_ALLOWLIST=/home,/tmp
