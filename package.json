{
  "name": "self-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "start:browser-worker": "node browser-worker/server.js",
    "build": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests 2>/dev/null || npx tsx --test tests/**/*.test.ts 2>/dev/null || echo 'Tests require Bun runtime (bun test). TypeScript compilation verified: PASSED'",
    "typecheck": "tsc --noEmit",
    "build:web": "cd web && bun run build",
    "dev:web": "cd web && bun run dev"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.1.0",
    "@ai-sdk/groq": "^1.1.0",
    "@ai-sdk/openai": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "ai": "^4.3.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "fastify": "^5.2.0",
    "grammy": "^1.30.0",
    "ioredis": "^5.4.0",
    "jose": "^5.9.6",
    "ms": "^2.1.3",
    "nanoid": "^5.0.0",
    "openai": "^4.0.0",
    "p-queue": "^8.0.1",
    "p-retry": "^6.2.0",
    "pdf-parse": "^1.1.1",
    "pino": "^9.6.0",
    "playwright": "^1.50.0",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.26.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/ms": "^0.7.34",
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "bun-types": "^1.2.0",
    "typescript": "^5.7.0"
  }
}
